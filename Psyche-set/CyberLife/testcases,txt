    emotion="frustrated",
    importance=0.8,
    context="coding interviews"
)
memories = linx.Brain.mind.get_all()
latest = memories[-1]
assert 'rosa_meta' in latest
assert latest['rosa_meta']['rosa_processed'] == True
print("✓ LINX syncs to ROSA")
```
**Dependencies:** Test #2
**Priority:** CRITICAL

